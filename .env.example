# Claude Imprint environment example
# Copy this file to .env, then edit values for your machine:
#   cp .env.example .env
#
# Never commit your real .env file. It may contain personal data paths,
# Telegram tokens, Cloudflare tokens, and OAuth credentials.

# ─────────────────────────────────────────────────────────────
# Core data paths
# ─────────────────────────────────────────────────────────────

# Shared data directory used by Memory HTTP, Dashboard, hooks, cron,
# heartbeat, and external connectors. Keep this value consistent everywhere.
# Docker compose overrides this to /data/imprint inside containers.
IMPRINT_DATA_DIR=~/.imprint

# Optional explicit SQLite path. Leave empty to use:
#   $IMPRINT_DATA_DIR/memory.db
IMPRINT_DB=

# Timezone offset in hours, used by Dashboard and logs.
# Examples: 8 for UTC+8, -5 for US Eastern Standard Time.
TZ_OFFSET=0

# ─────────────────────────────────────────────────────────────
# Dashboard / HTTP runtime
# ─────────────────────────────────────────────────────────────

# Host ports exposed by docker-compose.yml.
MEMORY_HTTP_PORT=8000
DASHBOARD_PORT=3000

# ─────────────────────────────────────────────────────────────
# LLM / compression / extraction
# ─────────────────────────────────────────────────────────────

# OpenAI-compatible LLM endpoint used by memory extraction or compression
# when the underlying memory package is configured to call an external LLM.
# Examples:
#   https://api.deepseek.com/v1
#   https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Ollama endpoint for local models. In docker compose with the optional
# "vector" profile, use http://ollama:11434. On host machines, use
# http://localhost:11434.
OLLAMA_URL=http://localhost:11434

# Model used by context compression fallback paths.
COMPRESS_MODEL=goekdenizguelmez/JOSIEFIED-Qwen3:8b

# ─────────────────────────────────────────────────────────────
# Emotional decay / surfacing
# ─────────────────────────────────────────────────────────────

# Decay lambda controls how quickly non-protected memories fade.
DECAY_LAMBDA=0.05

# Memories below this decay score may be treated as low-priority or archived.
DECAY_THRESHOLD=0.30

# Unresolved memories with arousal >= this value can be surfaced proactively.
AROUSAL_SURFACING_THRESHOLD=0.70

# ─────────────────────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────────────────────

# BotFather token. Required only when using imprint-telegram MCP to send
# Telegram messages/files via Bot API.
TELEGRAM_BOT_TOKEN=

# Default target chat id for send_telegram / send_telegram_photo.
# Get it from @userinfobot or Telegram getUpdates.
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────
# Heartbeat / automation
# ─────────────────────────────────────────────────────────────

# Heartbeat interval in seconds.
HEARTBEAT_INTERVAL=900

# Quiet hours for proactive notifications.
QUIET_START=23
QUIET_END=7

# ─────────────────────────────────────────────────────────────
# Cloudflare Tunnel
# ─────────────────────────────────────────────────────────────

# Optional named tunnel token if you run a managed Cloudflare Tunnel.
# The default docker-compose tunnel profile uses a temporary quick tunnel
# and does not require this token.
CLOUDFLARE_TUNNEL_TOKEN=
